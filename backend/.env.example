# Local overrides for Django. Copy to `.env` and fill in values.
# `.env` is gitignored — never commit real secrets.
#
#   cp .env.example .env
#
# Optional: load into your shell (same keys) with direnv, or run Django via
# a process manager that injects env (systemd, Docker, etc.).

# Required in production; optional locally (settings fall back to dev default).
# DJANGO_SECRET_KEY=

# Logging (see config/settings.py)
# DJANGO_LOG_LEVEL=INFO
# API_LOG_LEVEL=INFO
